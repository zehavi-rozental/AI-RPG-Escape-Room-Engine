# הגדרות שרת בסיסיות
PORT=5000
NODE_ENV=development

# חיבור למסד הנתונים MongoDB
# הכניסי כאן את כתובת החיבור המלאה שקיבלת מ-MongoDB Atlas
MONGO_URI=

# אבטחה וטוקנים
# מחרוזת אקראית ומורכבת לאבטחת טוקני התחברות
JWT_SECRET=

# מפתח API עבור Google Gemini
GEMINI_API_KEY=

# הגדרות Redis
REDIS_URL=redis://localhost:6379

# הגדרות נוספות
CORS_ORIGIN=http://localhost:3000